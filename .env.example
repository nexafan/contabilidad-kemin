# =============================================================================
# Panel KEMIN — variables de entorno
# Copia este archivo a `.env` y rellena los valores. NUNCA commitees `.env`.
# =============================================================================

# Puerto del servidor
# OJO: en el VPS Hetzner 37.27.216.31, 4123 = panel NexaFans contable,
# 4124 = panel NexaFans reclutamiento. KEMIN usa 4125 por defecto.
PORT=4125

# Usuarios del panel (auth básica). Formato: "user1:pass1,user2:pass2"
# Ejemplo con dos socios:
PANEL_USERS=fer:cambia_esta_password,kevin:cambia_esta_password

# Claude API (para OCR de capturas)
# Crea una key en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5

# DB
DB_PATH=./data/kemin.db

# Storage de capturas
UPLOADS_DIR=./uploads

# Umbral para que un evento aparezca como tab automática
EVENT_AUTO_TAB_THRESHOLD=40

# Cashback Slash (en decimal, 0.02 = 2%)
SLASH_CASHBACK_RATE=0.02

# Backblaze B2 (opcional pero recomendado)
# Crea bucket privado + Application Key en https://secure.backblaze.com/app_keys.htm
# Si no lo configuras, el backup solo es local.
B2_ENABLED=false
B2_BUCKET=kemin-backups
B2_KEY_ID=
B2_APP_KEY=
B2_REGION=us-west-002
