{
  "name": "contabilidad-kemin",
  "version": "0.1.0",
  "description": "Panel de contabilidad y stock de tickets para KEMIN LLC (resale). SQLite local + OCR de capturas con Claude vision. Sin Notion.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "init-db": "node -e \"import('./server.js').then(() => process.exit(0))\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nexafan/contabilidad-kemin"
  },
  "license": "MIT",
  "keywords": ["tickets", "resale", "stubhub", "ocr", "panel", "sqlite", "claude-vision"]
}
